{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/praxis-rs/praxis/docs/report-schema.json",
  "title": "Praxis Pre-Audit Report",
  "description": "Schema for reports emitted by `praxis report` (version 1).",
  "type": "object",
  "required": ["schema_version", "program", "summary", "findings", "generated_at"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Schema version — always '1' for this format."
    },
    "program": {
      "type": "object",
      "required": ["name", "program_id", "version"],
      "properties": {
        "name":       { "type": "string" },
        "program_id": { "type": "string", "description": "Base-58 encoded on-chain program ID." },
        "version":    { "type": "string", "description": "Semver version of the program under test." }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "critical", "high", "medium", "info"],
      "properties": {
        "total":    { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "high":     { "type": "integer", "minimum": 0 },
        "medium":   { "type": "integer", "minimum": 0 },
        "info":     { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "message"],
        "properties": {
          "id":          { "type": "string", "description": "Check ID (e.g. AC-001) or fuzzer finding ID." },
          "severity":    { "type": "string", "enum": ["info", "medium", "high", "critical"] },
          "message":     { "type": "string" },
          "location":    { "type": ["string", "null"] },
          "replay_seed": { "type": ["string", "null"], "description": "Hex seed for `praxis replay --seed`." }
        }
      }
    },
    "profile": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["name", "avg_cu", "max_cu", "pct_of_total"],
        "properties": {
          "name":         { "type": "string" },
          "avg_cu":       { "type": "integer", "minimum": 0 },
          "max_cu":       { "type": "integer", "minimum": 0 },
          "pct_of_total": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp of report generation."
    }
  }
}
